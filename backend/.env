# ── ParkEasy Backend Environment Variables ──────────────────────
# Copy this file to .env and adjust values as needed.

SECRET_KEY=parkeasy-super-secret-key-change-in-prod
JWT_SECRET=parkeasy-jwt-secret-key-change-in-prod
JWT_EXPIRY_HOURS=24

MONGO_URI=mongodb+srv://parkmate_admin:securepassword@cluster0.qnxa6am.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=parkmateDB

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://codecraze-demo.vercel.app,https://codecraze-demo.onrender.com

PARKING_RATE_PER_HOUR=20.0

# ─── SMTP Email (Gmail) ────────────────────────────────────────────────────
# Replace the values below with your Gmail credentials.
# IMPORTANT: Use a Gmail App Password, NOT your regular Gmail password.
# Steps to create an App Password:
#   1. Go to myaccount.google.com → Security
#   2. Enable 2-Step Verification if not already enabled
#   3. Go to Security → App passwords
#   4. Select "Mail" and generate a 16-character password
#   5. Paste it below (no spaces)
